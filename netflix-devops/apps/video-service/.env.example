# Video Service Environment Variables
NODE_ENV=development
PORT=3002
APP_NAME=netflix-video-service

# MongoDB
MONGODB_URI=mongodb://localhost:27017/netflix
MONGODB_USER=admin
MONGODB_PASSWORD=changeme

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# File Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads
MAX_FILE_SIZE=5368709120

# Video Processing
VIDEO_QUALITY_PRESET=medium
ENABLE_TRANSCODING=false

# Logging
LOG_LEVEL=debug

# Streaming
STREAMING_CHUNK_SIZE=262144
STREAM_BUFFER_SIZE=5242880
