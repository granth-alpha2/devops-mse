# ========================================
# Netflix DevOps - Environment Configuration
# ========================================
# Copy this file to .env and update values

# --- Database ---
MONGO_USER=admin
MONGO_PASSWORD=password
MONGODB_URI=mongodb://admin:password@mongodb:27017/netflix?authSource=admin

# --- Authentication ---
JWT_SECRET=change-this-to-a-strong-random-secret

# --- CORS ---
# Use * for development, specific origins for production
CORS_ORIGIN=*

# --- Demo User ---
DEMO_USER_NAME=Netflix Demo User
DEMO_USER_EMAIL=demo@netflix.local
DEMO_USER_PASSWORD=demo123
DEMO_USER_TIER=premium

# --- Service Ports ---
BACKEND_PORT=5000
AUTH_PORT=5001
VIDEO_PORT=5002
FRONTEND_PORT=3000

# --- Monitoring ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- Frontend ---
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_DEMO_USER_EMAIL=demo@netflix.local
REACT_APP_DEMO_USER_PASSWORD=demo123
